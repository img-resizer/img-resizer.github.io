---
const {posts}=Astro.props;
---
<div class="posts">{posts.map((post:any,index:number)=><article class:list={{featured:index===0}}><div class="post-meta"><span>{post.data.category}</span><time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en',{dateStyle:'medium'})}</time></div><h2><a href={`/blog/${post.id.replace(/\.(md|mdx)$/,'')}/`}>{post.data.title}</a></h2><p>{post.data.description}</p><div class="tags">{post.data.tags.map((tag:string)=><a href={`/blog/tag/${tag}/`}>#{tag}</a>)}</div><a class="read" href={`/blog/${post.id.replace(/\.(md|mdx)$/,'')}/`}>Read guide <span aria-hidden="true">↗</span></a></article>)}</div><style>.posts{display:grid;grid-template-columns:repeat(2,1fr);gap:1rem}.posts article{position:relative;min-height:310px;padding:1.6rem;border:1px solid var(--line);border-radius:var(--radius);background:#fff;box-shadow:var(--shadow-sm)}.posts article.featured{background:var(--ink);color:#fff}.post-meta{display:flex;justify-content:space-between;color:#8995a7;font-size:.72rem;font-weight:800;letter-spacing:.07em;text-transform:uppercase}.posts h2{max-width:490px;margin:2.4rem 0 .7rem;font-size:clamp(1.45rem,2.5vw,2rem);line-height:1.15;letter-spacing:-.035em}.posts h2 a{text-decoration:none}.posts p{max-width:540px;color:var(--ink-soft)}.featured p{color:#c6ccda}.tags{margin-top:1rem}.tags a{margin-right:.55rem;color:var(--blue);font-size:.78rem;text-decoration:none}.featured .tags a{color:var(--lime)}.read{position:absolute;right:1.6rem;bottom:1.5rem;color:inherit;font-size:.83rem;font-weight:800;text-decoration:none}@media(max-width:650px){.posts{grid-template-columns:1fr}}</style>
