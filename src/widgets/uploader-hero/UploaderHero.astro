---
import type { Preset } from '../../entities/preset/model/types';
const {preset}=Astro.props as {preset?:Preset};
const format=preset?.format??'image/jpeg';
const isBatch=preset?.utility==='batch';
---
<section class="workspace" data-tool data-batch={isBatch?'true':'false'} data-width={preset?.width??''} data-height={preset?.height??''} data-format={format} data-max-size={preset?.maxSizeKB??''} aria-label="Image resizing workspace">
  <div class="workspace-bar"><div><span class="live-dot"></span><strong>Local workspace</strong><span>Nothing is uploaded</span></div><span class="shortcut">JPEG · PNG · WEBP</span></div>
  <div class="workspace-grid">
    <div class="canvas-panel">
      <label class="dropzone" data-dropzone>
        <input data-file-input type="file" accept="image/jpeg,image/png,image/webp" multiple={isBatch || undefined} />
        <span class="upload-mark" aria-hidden="true"><span>+</span></span>
        <strong>{isBatch?'Drop images here':'Drop an image here'}</strong><span>or click to browse your device</span><small>{isBatch?'Select up to 20 files at once':'JPEG, PNG, or WebP'}</small>
      </label>
      <div class="preview" data-preview hidden><div class="preview-stage"><img data-preview-image alt="Preview of the selected image" /></div><div class="batch-list" data-batch-list hidden></div><div class="file-row"><div><strong data-file-name></strong><span data-file-meta></span></div><button class="text-button" type="button" data-replace>{isBatch?'Choose other files':'Replace'}</button></div></div>
    </div>
    <form class="settings" data-settings>
      <div class="settings-head"><div><span class="step">01</span><h2>Output settings</h2></div><button type="reset" class="text-button">Reset</button></div>
      <div class="control-pair"><label>Width<input data-width type="number" inputmode="numeric" min="1" max="12000" placeholder="Auto" value={preset?.width}/><span>px</span></label><span class="dimension-sign">×</span><label>Height<input data-height type="number" inputmode="numeric" min="1" max="12000" placeholder="Auto" value={preset?.height}/><span>px</span></label></div>
      <label class="ratio-option"><input data-lock type="checkbox" checked/><span><b>Keep aspect ratio</b><small>Turn this off to set width and height independently.</small></span></label>
      <label class="field"><span>Output format</span><select data-format><option value="image/jpeg" selected={format==='image/jpeg'}>JPEG, compact and compatible</option><option value="image/webp" selected={format==='image/webp'}>WebP, smaller modern format</option><option value="image/png" selected={format==='image/png'}>PNG, lossless graphics</option></select></label>
      <label class="field"><span>Maximum file size <small>optional</small></span><div class="input-unit"><input data-max-size type="number" inputmode="numeric" min="1" placeholder="No limit" value={preset?.maxSizeKB}/><b>KB</b></div></label>
      <div class="result-line"><span>Estimated output</span><strong data-estimate>Choose an image</strong></div>
      <button class="primary-button" type="submit" disabled data-process><span data-button-label>Resize and download</span><span aria-hidden="true">↓</span></button>
      <p class="status" data-status role="status">Your image stays on this device.</p>
    </form>
  </div>
</section>
<script>
  import { processImage } from '../../entities/image/lib/canvas';
  import { formatBytes } from '../../shared/lib/file';
  const root=document.querySelector<HTMLElement>('[data-tool]');
  if(root){
    const input=root.querySelector<HTMLInputElement>('[data-file-input]')!; const drop=root.querySelector<HTMLElement>('[data-dropzone]')!; const preview=root.querySelector<HTMLElement>('[data-preview]')!; const image=root.querySelector<HTMLImageElement>('[data-preview-image]')!; const batchList=root.querySelector<HTMLElement>('[data-batch-list]')!; const form=root.querySelector<HTMLFormElement>('[data-settings]')!; const width=root.querySelector<HTMLInputElement>('[data-width]')!; const height=root.querySelector<HTMLInputElement>('[data-height]')!; const format=root.querySelector<HTMLSelectElement>('[data-format]')!; const maxSize=root.querySelector<HTMLInputElement>('[data-max-size]')!; const processButton=root.querySelector<HTMLButtonElement>('[data-process]')!; const status=root.querySelector<HTMLElement>('[data-status]')!; const estimate=root.querySelector<HTMLElement>('[data-estimate]')!; const lock=root.querySelector<HTMLInputElement>('[data-lock]')!;
    let files:File[]=[]; let previewUrl=''; let ratio=1; let linked=true;
    const renderBatch=()=>{batchList.replaceChildren();const batch=root.dataset.batch==='true';batchList.hidden=!batch||files.length<2;if(!batch)return;for(const file of files){const item=document.createElement('div');const thumb=document.createElement('img');const info=document.createElement('span');const name=document.createElement('b');const size=document.createElement('small');const url=URL.createObjectURL(file);thumb.src=url;thumb.alt='';thumb.onload=()=>URL.revokeObjectURL(url);name.textContent=file.name;size.textContent=formatBytes(file.size);info.append(name,size);item.append(thumb,info);batchList.append(item)}};
    const loadFiles=(list:FileList|File[])=>{files=Array.from(list).filter(file=>file.type.startsWith('image/')).slice(0,20); if(!files.length){status.textContent='Please choose a JPEG, PNG, or WebP image.';return} const file=files[0]; if(previewUrl)URL.revokeObjectURL(previewUrl); previewUrl=URL.createObjectURL(file); image.src=previewUrl; createImageBitmap(file).then(bitmap=>{ratio=bitmap.width/bitmap.height;if(!width.value&&!height.value){width.value=String(bitmap.width);height.value=String(bitmap.height)}bitmap.close();updateEstimate()}).catch(()=>{status.textContent='The preview is visible, but the image dimensions could not be read.'}); root.querySelector<HTMLElement>('[data-file-name]')!.textContent=file.name;root.querySelector<HTMLElement>('[data-file-meta]')!.textContent=`${formatBytes(file.size)} · ${files.length>1?files.length+' images selected':'ready to resize'}`;drop.hidden=true;preview.hidden=false;processButton.disabled=false;status.textContent='Preview ready. Adjust the output settings or download now.'};
    const updateEstimate=()=>{if(!files.length)return;const sourcePixels=image.naturalWidth*image.naturalHeight;const outputPixels=(Number(width.value)||image.naturalWidth)*(Number(height.value)||image.naturalHeight);const scale=Math.min(1,outputPixels/sourcePixels);const target=Number(maxSize.value)*1024;const value=target?Math.min(files[0].size*scale,target):files[0].size*scale;estimate.textContent=`About ${formatBytes(Math.max(500,Math.round(value)))}`};
    input.addEventListener('change',()=>{if(input.files){loadFiles(input.files);renderBatch()}}); root.querySelector('[data-replace]')?.addEventListener('click',()=>input.click());
    for(const name of ['dragenter','dragover'])drop.addEventListener(name,event=>{event.preventDefault();drop.classList.add('is-dragging')}); for(const name of ['dragleave','drop'])drop.addEventListener(name,event=>{event.preventDefault();drop.classList.remove('is-dragging')}); drop.addEventListener('drop',event=>{if(event.dataTransfer){loadFiles(event.dataTransfer.files);renderBatch()}});
    lock.addEventListener('change',()=>{linked=lock.checked}); width.addEventListener('input',()=>{if(linked&&ratio)height.value=String(Math.max(1,Math.round(Number(width.value)/ratio)));updateEstimate()});height.addEventListener('input',()=>{if(linked&&ratio)width.value=String(Math.max(1,Math.round(Number(height.value)*ratio)));updateEstimate()});format.addEventListener('change',updateEstimate);maxSize.addEventListener('input',updateEstimate);
    form.addEventListener('reset',()=>setTimeout(()=>{width.value=root.dataset.width||String(image.naturalWidth||'');height.value=root.dataset.height||String(image.naturalHeight||'');format.value=root.dataset.format||'image/jpeg';maxSize.value=root.dataset.maxSize||'';updateEstimate()},0));
    form.addEventListener('submit',async event=>{event.preventDefault();processButton.disabled=true;status.textContent=`Processing ${files.length} image${files.length===1?'':'s'} on this device...`;try{for(const file of files){const result=await processImage(file,{width:Number(width.value)||undefined,height:Number(height.value)||undefined,format:format.value as 'image/jpeg'|'image/png'|'image/webp',maxSizeKB:Number(maxSize.value)||undefined});const url=URL.createObjectURL(result.blob);const anchor=document.createElement('a');anchor.href=url;anchor.download=`resized-${file.name.replace(/\.[^.]+$/,'')}.${format.value.split('/')[1]}`;document.body.append(anchor);anchor.click();anchor.remove();setTimeout(()=>URL.revokeObjectURL(url),3000)}status.textContent=`Finished. ${files.length===1?'Your image is':'Your images are'} downloading now.`}catch(error){status.textContent=error instanceof Error?error.message:'The browser could not process this image.'}finally{processButton.disabled=false}});
  }
</script>
<style>.workspace{overflow:hidden;border:1px solid #ced6e2;border-radius:var(--radius-lg);background:var(--surface);box-shadow:var(--shadow)}.workspace-bar{display:flex;align-items:center;justify-content:space-between;min-height:56px;padding:.75rem 1.3rem;border-bottom:1px solid var(--line);background:#fbfcfe;color:var(--ink-soft);font-size:.82rem}.workspace-bar>div{display:flex;align-items:center;gap:.65rem}.workspace-bar strong{color:var(--ink)}.live-dot{width:8px;height:8px;border-radius:50%;background:#38b874;box-shadow:0 0 0 5px #daf5e7}.shortcut{padding:.25rem .55rem;border:1px solid var(--line);border-radius:6px;font-size:.67rem;letter-spacing:.06em}.workspace-grid{display:grid;grid-template-columns:minmax(0,1.28fr) minmax(330px,.72fr);min-height:520px}.canvas-panel{padding:1.35rem;background:#edf0f5}.dropzone{min-height:476px;border:1.5px dashed #aab5c5;border-radius:18px;background-color:#f7f9fc;background-image:linear-gradient(#e6eaf0 1px,transparent 1px),linear-gradient(90deg,#e6eaf0 1px,transparent 1px);background-size:24px 24px;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;cursor:pointer;transition:.2s}.dropzone:hover,.dropzone.is-dragging{border-color:var(--blue);background-color:var(--blue-pale);transform:translateY(-2px)}.dropzone input{position:absolute;width:1px;height:1px;opacity:0}.dropzone strong{margin-top:1rem;font-size:1.2rem}.dropzone>span{color:var(--ink-soft)}.dropzone small{margin-top:.65rem;color:#8290a5}.upload-mark{display:grid;place-items:center;width:76px;height:76px;border-radius:22px;background:var(--blue);box-shadow:0 14px 30px #1269e83b;color:#fff!important}.upload-mark span{font-size:2.4rem;font-weight:250;line-height:1}.preview-stage{height:400px;display:grid;place-items:center;overflow:hidden;border-radius:16px;background-color:#f7f9fc;background-image:linear-gradient(45deg,#e9edf3 25%,transparent 25%),linear-gradient(-45deg,#e9edf3 25%,transparent 25%),linear-gradient(45deg,transparent 75%,#e9edf3 75%),linear-gradient(-45deg,transparent 75%,#e9edf3 75%);background-size:20px 20px;background-position:0 0,0 10px,10px -10px,-10px 0}.preview-stage img{max-width:100%;max-height:100%;object-fit:contain;box-shadow:0 12px 35px #17203524}.file-row{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:1rem .3rem 0}.file-row>div{display:grid}.file-row span{color:var(--ink-soft);font-size:.8rem}.settings{display:flex;flex-direction:column;padding:1.65rem}.settings-head{display:flex;justify-content:space-between;align-items:center;padding-bottom:1.4rem;border-bottom:1px solid var(--line)}.settings-head>div{display:flex;align-items:center;gap:.7rem}.settings-head h2{font-size:1.15rem;letter-spacing:-.02em}.step{display:grid;place-items:center;width:31px;height:31px;border-radius:8px;background:var(--lime);font-size:.72rem;font-weight:850}.text-button{padding:0;border:0;background:transparent;color:var(--blue);font-weight:750}.control-pair{display:grid;grid-template-columns:1fr auto 1fr;align-items:end;gap:.55rem;margin:1.5rem 0}.control-pair label,.field{display:grid;gap:.45rem;color:var(--ink-soft);font-size:.78rem;font-weight:750}.control-pair label{position:relative}.control-pair input,.field select,.input-unit{height:48px;border:1px solid var(--line);border-radius:10px;background:#fff;color:var(--ink);font-size:.95rem}.control-pair input{width:100%;padding:0 2.2rem 0 .75rem}.control-pair label>span{position:absolute;right:.7rem;bottom:.75rem;color:#8995a7}.link-button{height:30px;margin-bottom:9px;border:0;border-radius:8px;background:var(--blue-pale);color:var(--blue);font-size:0}.link-button::after{content:"↔";font-size:1rem}.link-button[aria-pressed=false]{background:#f0f1f4;color:#8995a7}.field{margin-bottom:1.1rem}.field>span{display:flex;justify-content:space-between}.field small{font-weight:500}.field select{width:100%;padding:0 .75rem}.input-unit{display:flex;align-items:center}.input-unit input{width:100%;height:100%;padding:0 .75rem;border:0;background:transparent}.input-unit b{padding:0 .8rem;color:#8995a7}.result-line{display:flex;justify-content:space-between;margin:auto 0 1rem;padding-top:1.2rem;border-top:1px solid var(--line);color:var(--ink-soft);font-size:.85rem}.result-line strong{color:var(--ink)}.primary-button{display:flex;align-items:center;justify-content:space-between;width:100%;min-height:54px;padding:0 1.2rem;border:0;border-radius:12px;background:var(--blue);box-shadow:0 10px 22px #1269e82b;color:#fff;font-weight:800}.primary-button:hover{background:var(--blue-dark)}.primary-button:disabled{background:#c5ccd6;box-shadow:none;cursor:not-allowed}.status{min-height:22px;margin:.7rem 0 0;color:var(--ink-soft);font-size:.75rem;text-align:center}@media(max-width:860px){.workspace-grid{grid-template-columns:1fr}.workspace-grid,.dropzone{min-height:auto}.dropzone{height:390px}.preview-stage{height:350px}}@media(max-width:520px){.workspace-bar>div span:last-child,.shortcut{display:none}.canvas-panel{padding:.7rem}.dropzone{height:330px}.settings{padding:1.2rem}.control-pair{grid-template-columns:1fr 28px 1fr}}</style>
