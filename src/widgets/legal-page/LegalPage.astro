---
import BaseLayout from '../../app/layouts/BaseLayout.astro';
interface Props{title:string;description:string;eyebrow:string;updated?:string}
const {title,description,eyebrow,updated='July 22, 2026'}=Astro.props;
---
<BaseLayout {title} {description}>
  <article class="legal-page">
    <header><span class="eyebrow">{eyebrow}</span><h1><slot name="heading"/></h1><p>{description}</p><small>Last updated: {updated}</small></header>
    <div class="legal-body"><slot/></div>
  </article>
</BaseLayout>
<style>.legal-page{display:grid;grid-template-columns:minmax(260px,.6fr) minmax(0,1.4fr);gap:5rem;margin:4.5rem 0 7rem}.legal-page header{position:sticky;top:2rem;align-self:start}.legal-page header h1{font-size:clamp(2.6rem,5vw,4.7rem)}.legal-page header p{margin:1.2rem 0;color:var(--ink-soft);font-size:1.05rem}.legal-page header small{color:#8290a5}.legal-body{max-width:760px}.legal-body :global(h2){margin:2.3rem 0 .6rem;font-size:1.55rem;letter-spacing:-.025em}.legal-body :global(h2:first-child){margin-top:0}.legal-body :global(p),.legal-body :global(li){color:var(--ink-soft)}.legal-body :global(p+p){margin-top:1rem}.legal-body :global(ul){padding-left:1.25rem}.legal-body :global(a){color:var(--blue);font-weight:700}@media(max-width:760px){.legal-page{grid-template-columns:1fr;gap:2.5rem;margin-top:2.5rem}.legal-page header{position:static}}</style>
