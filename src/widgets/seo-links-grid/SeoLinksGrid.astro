---
import {presets} from '../../entities/preset/model/presets';
const groups=[{label:'Social dimensions',category:'dimensions',copy:'Exact canvas sizes for posts, covers, stories, and banners.'},{label:'File size targets',category:'file-size',copy:'Smaller downloads for forms, email, publishing, and storage.'},{label:'Focused utilities',category:'utility',copy:'Useful workflows for batches, signatures, and image grids.'}] as const;
---
<section class="section" aria-labelledby="tools-title"><div class="section-heading"><div><span class="eyebrow">Ready-made settings</span><h2 id="tools-title" class="section-title">Start with the right target</h2></div><p class="section-lead">Each tool opens the same private image resizer with dimensions, format, or maximum file size already prepared.</p></div><div class="groups">{groups.map((group,index)=><article class="group"><span class="group-number">0{index+1}</span><h3>{group.label}</h3><p>{group.copy}</p><ul>{presets.filter(p=>p.category===group.category).slice(0,group.category==='file-size'?10:7).map(p=><li><a href={`/tool/${p.slug}`}><span>{p.title}</span><b aria-hidden="true">↗</b></a></li>)}</ul></article>)}</div></section>
<style>.groups{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem}.group{position:relative;padding:1.5rem;border:1px solid var(--line);border-radius:var(--radius);background:#fff;box-shadow:var(--shadow-sm)}.group-number{position:absolute;top:1.2rem;right:1.3rem;color:#a2adbc;font-size:.72rem;font-weight:850;letter-spacing:.08em}.group h3{font-size:1.2rem;letter-spacing:-.025em}.group>p{min-height:50px;margin:.4rem 0 1.1rem;color:var(--ink-soft);font-size:.88rem}.group ul{list-style:none;padding:0}.group li{border-top:1px solid #edf0f4}.group a{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:.65rem 0;color:var(--ink);font-size:.87rem;font-weight:700;text-decoration:none}.group a b{color:var(--blue);font-weight:500}.group a:hover span{color:var(--blue)}@media(max-width:850px){.groups{grid-template-columns:1fr 1fr}.group:last-child{grid-column:1/-1}}@media(max-width:590px){.groups{grid-template-columns:1fr}.group:last-child{grid-column:auto}.group>p{min-height:0}}</style>
