<label class="dropzone" id="dropzone">
  <input id="file-input" type="file" accept="image/*" multiple />
  <span class="icon" aria-hidden="true">↑</span>
  <strong>Drop images here or choose files</strong>
  <small>JPEG, PNG or WebP · processed only on your device</small>
</label>
<style>.dropzone{min-height:250px;border:2px dashed #aebbe0;border-radius:1rem;background:linear-gradient(145deg,#f8faff,#eef2ff);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:.45rem;padding:2rem;transition:.2s}.dropzone:hover,.dropzone.dragging{border-color:var(--primary);background:#eef2ff}.dropzone input{position:absolute;width:1px;height:1px;opacity:0}.icon{display:grid;place-items:center;width:48px;height:48px;border-radius:50%;background:#fff;color:var(--primary);font-size:1.7rem;box-shadow:0 6px 20px #4f46e51c}.dropzone strong{font-size:1.05rem}.dropzone small{color:var(--muted)}</style>
