---
import LegalPage from '../widgets/legal-page/LegalPage.astro';
const title = 'Contact Us | Image Resizer';
const description =
	'Contact the Image Resizer team about the website, image tools, accessibility, privacy, or technical problems.';
---

<LegalPage
	{title}
	{description}
	eyebrow='Contact'
	><span slot='heading'>Contact us</span><h2>How to reach us</h2><p
		>Use the project contact details that will be published on this page. The public support address
		has intentionally been left out so it can be added before launch.</p
	><p
		>When reporting a technical problem, describe the page you opened, the image format you used,
		the browser, and what happened after you selected the file. Do not send private or sensitive
		images as examples.</p
	><h2>What we can help with</h2><ul
		><li>Problems with image resizing or compression</li><li
			>Questions about supported image formats</li
		><li>Accessibility feedback</li><li>Privacy and data-processing questions</li><li
			>Corrections to guides or preset dimensions</li
		></ul
	><h2>Before contacting us</h2><p
		>Image processing takes place in your browser. We cannot retrieve images, restore deleted
		originals, or access files processed on your device. Keep a copy of the source image until you
		have checked the downloaded result.</p
	><h2>Response information</h2><p
		>Support availability and expected response times will be listed here when the contact channel
		is added.</p
	>
	Contact us via <a href='https://github.com/jstoolsspace'>GitHub</a></LegalPage
>
