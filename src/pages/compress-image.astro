---
import BaseLayout from '../app/layouts/BaseLayout.astro'; import UploaderHero from '../widgets/uploader-hero/UploaderHero.astro'; import SeoLinksGrid from '../widgets/seo-links-grid/SeoLinksGrid.astro'; import type {Preset} from '../entities/preset/model/types';
const preset:Preset={slug:'compress-image',title:'Compress Image Online',description:'Compress an image to a smaller file size without uploading it.',category:'utility',format:'image/jpeg'};
const title='Compress Image Online | Image Resizer'; const description='Compress images online to a smaller JPEG, PNG, or WebP file. Set a maximum file size, preview the source, and process it privately in your browser.';
---
<BaseLayout {title} {description}><UploaderHero {preset}/><section class="intro"><div><span class="eyebrow">Dedicated compressor</span><h1>Compress Image Online</h1></div><p class="intro-copy"><strong>Reduce image file size with direct control.</strong>Choose an image, select JPEG, PNG, or WebP, enter an optional maximum size, and download the compressed result without uploading the source.</p></section><section class="section compress-copy"><div><span class="eyebrow">Smaller files</span><h2 class="section-title">Image compression for practical limits</h2></div><div><p>Large images take longer to send, occupy more storage, and can be rejected by forms or publishing systems. This image compressor reduces the file while keeping the workflow visible. The selected picture appears in the workspace before any processing begins.</p><p>JPEG and WebP compression adjusts encoding quality toward the maximum size you enter. PNG works differently because it is a lossless format. When a strict PNG limit cannot be reached through encoding alone, the compressor can reduce the pixel dimensions.</p><h3>Choose a useful target</h3><p>Use the largest file size accepted by the destination when visual quality matters. A 500 KB photograph usually preserves more detail than a 50 KB version. Small signatures, document scans, and thumbnails may need much less data.</p><h3>Compression stays local</h3><p>The image is read and compressed by your browser. It is not added to an upload queue, stored in an account, or transferred to a remote processing service.</p></div></section><SeoLinksGrid/></BaseLayout>
<style>.compress-copy{display:grid;grid-template-columns:.7fr 1.3fr;gap:4rem}.compress-copy p{color:var(--ink-soft)}.compress-copy p+p{margin-top:1rem}.compress-copy h3{margin:2rem 0 .5rem}@media(max-width:760px){.compress-copy{grid-template-columns:1fr;gap:1.5rem}}</style>
